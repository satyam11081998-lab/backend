OPENAI_API_KEY=sk-REPLACE-ME
SUPABASE_URL=https://REPLACE-ME.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE-ME
# Deck Vault Rewards — admin Telegram alerts (leave empty to disable alerts).
# Chat id is read from TELEGRAM_ADMIN_CHAT_ID or TELEGRAM_CHAT_ID (either name works).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Deck Vault Rewards — Google Drive storage. Use the SAME values as the Vercel
# web app (lib/google-drive.ts). Either the OAuth trio or the SA pair works.
# If none are set, submissions fall back to the private Supabase bucket.
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_SA_CREDENTIALS=
GOOGLE_SA_CLIENT_EMAIL=
GOOGLE_SA_PRIVATE_KEY=
GDRIVE_FOLDER_ID=
# Optional: separate Drive folder just for reward submissions (falls back to GDRIVE_FOLDER_ID)
GDRIVE_SUBMISSIONS_FOLDER_ID=